# Server Port
PORT=4000

# Environment (development, production, test)
NODE_ENV=development

# Database Connection URI (Supabase PostgreSQL Connection String)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# Upstash Redis Connection URI
UPSTASH_REDIS_URL="rediss://default:YOUR_TOKEN@YOUR_HOST.upstash.io:6379"

# JWT Secrets (Minimum 32 characters — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_ACCESS_SECRET=your_32_char_access_secret_here
JWT_REFRESH_SECRET=your_32_char_refresh_secret_here

# ImageKit Credentials
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id

# Groq LLM API Key
GROQ_API_KEY=your_groq_api_key

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key

# CORS allowed origins — REQUIRED in production. Comma-separated.
# Example: https://contextchat.vercel.app,https://contextchat.app
# Leave unset in development to allow all origins.
CORS_ORIGIN=
